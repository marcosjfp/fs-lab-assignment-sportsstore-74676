@model SportsStore.Models.Order

@{
    bool cancelled = Model.PaymentStatus == "canceled";
}

<h2 class="text-danger">Payment @(cancelled ? "Cancelled" : "Failed")</h2>

@if (cancelled) {
    <p>Your payment was cancelled. You can try again below.</p>
} else {
    <p>Unfortunately your payment could not be processed. Please try a different card.</p>
}

<a asp-controller="Order" asp-action="Payment" asp-route-orderId="@Model.OrderID"
   class="btn btn-primary">Try Again</a>
<a asp-controller="Home" asp-action="Index" class="btn btn-secondary ms-2">Return to Store</a>

